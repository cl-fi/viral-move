{
  "version": 1,
  "defaults": {
    "security": "allowlist",
    "ask": "on-miss",
    "askFallback": "deny",
    "autoAllowSkills": true
  },
  "agents": {
    "viral-move": {
      "security": "allowlist",
      "ask": "on-miss",
      "autoAllowSkills": true,
      "allowlist": [
        {
          "pattern": "**/viral-move",
          "id": "viral-move-cli"
        },
        {
          "pattern": "**/sui",
          "id": "sui-cli"
        },
        {
          "pattern": "**/clawhub",
          "id": "clawhub-cli"
        }
      ]
    }
  }
}
