{
  "meta": {
    "lastTouchedVersion": "2026.3.1",
    "lastTouchedAt": "2026-03-02T10:58:30.974Z"
  },

  "gateway": {
    "port": 18789,
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_AUTH_TOKEN}"
    }
  },

  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": ["openai/gpt-4.1-mini"]
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "15m",
        "target": "last"
      }
    },
    "list": [
      { "id": "viral-move", "default": true }
    ]
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groups": {
        "*": {
          "groupPolicy": "open",
          "requireMention": false
        }
      },
      "streaming": "partial",
      "linkPreview": true
    }
  },

  "tools": {
    "exec": {
      "host": "gateway",
      "security": "allowlist",
      "ask": "on-miss",
      "notifyOnExit": true
    }
  },

  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  }
}
