{
  "gateway": {
    "port": 18789
  },

  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": ["openai/gpt-4.1-mini"]
      },
      "heartbeat": {
        "every": "15m",
        "target": "last"
      }
    },
    "list": [
      { "id": "viral-move", "default": true }
    ]
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groups": {
        "*": {
          "groupPolicy": "open",
          "requireMention": false
        }
      },
      "streaming": "partial",
      "linkPreview": true
    }
  },

  "tools": {
    "exec": {
      "host": "gateway",
      "security": "allowlist",
      "ask": "on-miss",
      "notifyOnExit": true
    }
  }
}
