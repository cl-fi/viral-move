# ─── Sui Configuration ───────────────────────────────────
SUI_NETWORK=testnet
SUI_PRIVATE_KEY=suiprivkey...

# ─── OpenClaw LLM Provider ──────────────────────────────
# OpenClaw uses this to power the agent's brain (conversation, decisions)
# Set ONE of these (OpenClaw reads them directly):
GEMINI_API_KEY=your_google_ai_studio_key
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── Telegram Bot ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHANNEL_ID=@your_channel_name_or_numeric_id

# ─── Walrus (defaults to testnet endpoints) ─────────────
# WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=5

# ─── Token Factory ──────────────────────────────────────
TOKEN_TEMPLATE_DIR=./contracts/token-template
GENERATED_CONTRACTS_DIR=./contracts/generated

# ─── Self-Evolution ─────────────────────────────────────
SKILLS_DIR=./workspace/skills
SOUL_MD_PATH=./workspace/SOUL.md

# ─── Agent Timing ───────────────────────────────────────
POLL_INTERVAL_MS=60000
MONITOR_ROUNDS=4
MONITOR_INTERVAL_MS=30000
